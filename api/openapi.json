{
  "openapi": "3.0.3",
  "info": {
    "title": "Ultiorganizer API",
    "version": "1.0.0",
    "description": "Public read-only API for teams, games, and gameplay data."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiTokenAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Token",
        "description": "Send the token as Authorization: Bearer <token>."
      }
    }
  },
  "paths": {
    "/api/v1/events": {
      "get": {
        "summary": "List all events available on the server",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Events response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/version": {
      "get": {
        "summary": "Get Ultiorganizer, database, and customization version information",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Version response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "status": "ok",
                  "data": {
                    "ultiorganizer": {
                      "version": "4.0",
                      "major": 4,
                      "minor": 0
                    },
                    "api": {
                      "version": "v1"
                    },
                    "database": {
                      "version": 90
                    },
                    "customization": {
                      "id": "slkl",
                      "version": "1.0"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/teams": {
      "get": {
        "summary": "List teams for an event",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "event",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Event id."
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["name", "seeding"]
            },
            "description": "Order teams by name or seeding."
          }
        ],
        "responses": {
          "200": {
            "description": "Teams response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/divisions": {
      "get": {
        "summary": "List divisions and pools for an event",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "event",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Event id."
          }
        ],
        "responses": {
          "200": {
            "description": "Divisions response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/games": {
      "get": {
        "summary": "List games for the current event",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "parameters": [
          { "name": "event", "in": "query", "schema": { "type": "string" }, "description": "Event id." },
          { "name": "division", "in": "query", "schema": { "type": "integer" } },
          { "name": "pool", "in": "query", "schema": { "type": "integer" } },
          { "name": "pools", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated pool ids." },
          { "name": "team", "in": "query", "schema": { "type": "integer" } },
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["tournaments", "divisions", "places", "timeslot", "today", "tomorrow", "yesterday", "next", "all"]
            }
          },
          { "name": "group", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Games response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/gameplay": {
      "get": {
        "summary": "Get gameplay details for a game",
        "security": [
          {
            "ApiTokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "game",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gameplay response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
