+	private function countriesForSeasonTeams(array $seasonTeams): array
+	{
+		$countriesById = [];
+		foreach (CountryList(true, true) as $country) {
+			$countriesById[(int) $country['country_id']] = $country;
+		}
+
+		$missingCountryIds = [];
+		foreach ($seasonTeams as $team) {
+			$countryId = (int) ($team['country'] ?? 0);
+			if ($countryId > 0 && !isset($countriesById[$countryId])) {
+				$missingCountryIds[] = $countryId;
+			}
+		}
+
+		$loadedMissingCountryIds = [];
+		foreach (CountriesByIds($missingCountryIds) as $country) {
+			$loadedMissingCountryIds[(int) $country['country_id']] = true;
+			$countriesById[(int) $country['country_id']] = $country;
+		}
+
+		foreach (array_unique($missingCountryIds) as $countryId) {
+			if (isset($loadedMissingCountryIds[$countryId])) {
+				continue;
+			}
+
+			$countriesById[$countryId] = [
+				'country_id' => $countryId,
+				'name' => '',
+				'abbreviation' => '',
+				'flagfile' => '',
+			];
+		}
+
+		uasort($countriesById, function ($countryA, $countryB) {
+			return strcmp($countryA['name'], $countryB['name']);
+		});
+
+		return array_values($countriesById);
+	}
 
