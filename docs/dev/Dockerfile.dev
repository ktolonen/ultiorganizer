FROM php:8.3-apache

RUN apt-get update && apt-get install -y \
    curl \
    gettext \
    git \
    libjpeg62-turbo-dev \
    less \
    libonig-dev \
    locales \
    default-mysql-client \
    libpng-dev \
    nodejs \
    npm \
    ripgrep \
    unzip \
    zlib1g-dev \
 && sed -i '/^# *en_US.UTF-8 UTF-8/s/^# *//' /etc/locale.gen \
 && sed -i '/^# *fi_FI.UTF-8 UTF-8/s/^# *//' /etc/locale.gen \
 && locale-gen en_US.UTF-8 fi_FI.UTF-8 \
 && pecl install xdebug \
 && docker-php-ext-enable xdebug \
 && docker-php-ext-configure gd --with-jpeg \
 && docker-php-ext-install mysqli gettext gd mbstring \
 && curl -sSf https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer \
 && rm -rf /var/lib/apt/lists/*

# JS linting toolchain. Installed into a self-contained prefix so the repo
# doesn't need a package.json, and exposed via NODE_PATH + PATH so the
# eslint.config.js can require() these packages from anywhere in the tree.
RUN mkdir -p /opt/eslint \
 && cd /opt/eslint \
 && npm install --no-save --no-package-lock \
      eslint@9.16.0 \
      @eslint/js@9.16.0 \
      eslint-plugin-html@8.1.2 \
      globals@15.13.0 \
 && npm cache clean --force
ENV NODE_PATH=/opt/eslint/node_modules
ENV PATH=/opt/eslint/node_modules/.bin:$PATH

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
WORKDIR /workspace
